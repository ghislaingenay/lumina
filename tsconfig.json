{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@types/*": ["./types/index.ts"],
      "@hooks/*": ["./hooks/*"],
      "@components/*": ["./components/*"],
      "@ui/*": ["./components/ui/*"],
      "@layouts/*": ["./components/layouts/*"],
      "@draco/*": ["./draco/*"],
      "@providers/*": ["./providers/*"],
      "@modules/*": ["./modules/*/index.tsx"],
      "@constants/*": ["lib/constants/*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "./index.d.ts"
  ],
  "exclude": ["node_modules"]
}
