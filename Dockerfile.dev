FROM node:22-alpine

WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose the development port (Next.js default)
EXPOSE 3000

# Start the development server with hot reload
CMD ["npm", "run", "dev"]